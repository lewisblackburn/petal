generator client {
  provider = "prisma-client-js"
}

generator typegraphql {
  provider = "typegraphql-prisma"
  output   = "../../../../node_modules/@generated"
  emitOnly = "inputs,outputs,models,enums,crudResolvers"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String     @unique
  /// @TypeGraphQL.omit(output: true)
  password  String
  firstName String
  lastName  String
  twitter   String?
  instagram String?
  avatar    String?
  role      Role       @default(USER)
  bio       String?
  movies    Movie[]
  lists     List[]
  ratings   Rating[]
  logs      Log[]
  watchlist Watchlist?
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
}

enum Status {
  RUMORED
  PLANNED
  IN_PRODUCTION
  POST_PRODUCTION
  RELEASED
  CANCELLED
}

// Change to Actual Model Instead (easier for table sorting and such)
enum Genre {
  ACTION
  ADVENTURE
  ANIMATION
  COMEDY
  CRIME
  MYSTERY
  FANTASY
  HISTORICAL
  HORROR
  ROMANCE
  SATIRE
  SCIENCE_FICTION
  CYBERPUNK
  SPECULATIVE
  THRILLER
  WESTERN
}

enum AgeRating {
  U
  PG
  TWELVEA
  TWELVE
  EIGHTEEN
}

model Platform {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  movies    Movie[]
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}

model Rating {
  value     Int
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.Uuid
  movie     Movie    @relation(fields: [movieId], references: [id])
  movieId   String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([userId, movieId])
}

enum MediaType {
  MOVIE
  PERSON
}

model Log {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user      User      @relation(fields: [userId], references: [id])
  userId    String    @db.Uuid
  type      MediaType
  mediaId   String    @db.Uuid
  key       String
  value     Json
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
}

model Person {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  avatar     String?
  characters Character[]
}

model Character {
  person   Person @relation(fields: [personId], references: [id])
  personId String @db.Uuid
  movie    Movie  @relation(fields: [movieId], references: [id])
  movieId  String @db.Uuid
  name     String

  @@unique([personId, movieId])
}

model Movie {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  overview     String
  tagline      String?
  genres       Genre[]
  lists        List[]
  watchlists   Watchlist[]
  ratings      Rating[]
  charaters    Character[]
  /// @TypeGraphQL.omit(input: ["update", "where", "orderBy"])
  popularity   Float?      @default(0)
  platforms    Platform[]
  age_rating   AgeRating?
  runtime      Int?        @default(0)
  homepage     String?
  language     String?
  videos       String[]
  posters      String[]
  backdrops    String[]
  keywords     String[]
  contentScore Int?
  locked       String[]
  adult        Boolean?    @default(false)
  budget       Int?        @default(0)
  revenue      Int?        @default(0)
  status       Status?     @default(PLANNED)
  releaseDate  DateTime?   @default(now()) @db.Timestamptz(6)
  user         User?       @relation(fields: [userId], references: [id])
  userId       String?     @db.Uuid
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
}

model List {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  backdrop    String?
  public      Boolean? @default(true)
  movies      Movie[]
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}

model Watchlist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  movies    Movie[]
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}
